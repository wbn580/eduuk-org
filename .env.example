# Copy this file to .env and fill in actual values after deployment.
# .env is already in .gitignore and will not be committed to the repository.

# ---------------------------------------------------------
# Google Search Console verification
# ---------------------------------------------------------
# How to obtain:
# 1. Open https://search.google.com/search-console
# 2. Add a property → URL prefix → enter https://eduuk.org
# 3. Choose "HTML tag" method and copy the content value from <meta name="google-site-verification" content="XXXXXX"/>
# 4. Paste XXXXXX below (without quotes)
# 5. After deployment, return to GSC and click "Verify"
PUBLIC_GOOGLE_SITE_VERIFICATION=

# ---------------------------------------------------------
# Cloudflare Web Analytics (optional)
# ---------------------------------------------------------
# In Cloudflare Pages dashboard: Analytics → Web Analytics → Add a site
# Cloudflare will provide a <script ... data-cf-beacon='{"token":"xxx"}'></script> snippet
# Fill in the token value below (currently unused in code, but available for future integration):
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# ---------------------------------------------------------
# Bing Webmaster Tools (optional)
# ---------------------------------------------------------
# Method is same as Google Search Console.
# Meta tag: <meta name="msvalidate.01" content="XXX"/>
PUBLIC_BING_VERIFICATION=

# ---------------------------------------------------------
# Yandex.Webmaster (optional, for global reach)
# ---------------------------------------------------------
# Meta tag: <meta name="yandex-verification" content="XXX"/>
PUBLIC_YANDEX_VERIFICATION=
