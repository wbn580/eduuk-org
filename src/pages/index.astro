---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { slugifyTag } from "@/utils/tagSlug";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

// 5 main categories for navigation. Tag values must match article frontmatter tags.
const categories = [
  { emoji: "🎓", name: "Universities", desc: "G5 / Russell / rankings" },
  { emoji: "📚", name: "Courses", desc: "Business / STEM / Arts" },
  { emoji: "🛂", name: "Visa", desc: "Student / Graduate Route" },
  { emoji: "🏠", name: "Accommodation", desc: "Halls / private / deposits" },
  { emoji: "🧋", name: "Life", desc: "Bank / NHS / transport" },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        UK Study, Answered Clearly
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="RSS Feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p>
        <strong>Study in UK</strong> is a knowledge base for international students headed to the United Kingdom. From G5 course choice and Student visa routes to halls, bank accounts, NHS registration and part-time work, we break the questions international students ask most into clear, factual answers — grounded in public data from UKVI, UCAS and HESA and real student experience. Facts first, updated regularly.
      </p>
      <p class="mt-2">
        Browse by category below, or learn more in
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="/about/"
        >
          About
        </LinkButton>.
      </p>
      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Contact:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="categories" class="pt-12 pb-6 border-b border-border">
      <h2 class="text-2xl font-semibold tracking-wide">Browse by Category</h2>
      <ul class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
        {categories.map(c => (
          <li>
            <a
              href={`/tags/${slugifyTag(c.name)}/`}
              class="flex h-full flex-col items-center gap-1 rounded-md border border-border px-3 py-4 text-center hover:border-accent hover:text-accent transition"
            >
              <span class="text-2xl leading-none">{c.emoji}</span>
              <span class="mt-1 text-sm font-medium">{c.name}</span>
              <span class="w-full truncate text-xs text-foreground/60">{c.desc}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured Q&A</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Updates</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        View all Q&A
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
