<script>
  document.addEventListener("astro:page-load", () => {
    const el = document.querySelector("#main-content") as HTMLElement | null;
    if (el?.dataset?.layout === "index") {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
