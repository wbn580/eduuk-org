---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
import { slugifyTag } from "@/utils/tagSlug";

const countries = [
  { emoji: "🇬🇧", name: "United Kingdom" },
  { emoji: "🇦🇺", name: "Australia" },
  { emoji: "🇳🇿", name: "New Zealand" },
  { emoji: "🇸🇬", name: "Singapore" },
  { emoji: "🇲🇾", name: "Malaysia" },
];
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    class="app-layout flex flex-1 flex-col items-center justify-center py-12"
  >
    <div class="flex w-full max-w-xl flex-col items-center text-center">
      <h1 class="text-8xl font-bold text-accent sm:text-9xl">404</h1>
      <p class="mt-4 text-2xl font-medium sm:text-3xl">Page Not Found</p>
      <p class="mt-3 text-base text-foreground/70">
        This page may have been archived, or the URL might be incorrect. Try these options to find what you're looking for:
      </p>

      <div class="mt-8 flex w-full flex-col gap-3 sm:flex-row sm:justify-center">
        <LinkButton
          href="/search/"
          class="rounded-full bg-accent px-6 py-3 text-sm font-medium text-background shadow-lg transition hover:-translate-y-0.5 hover:shadow-xl"
        >
          🔍 Search Q&A
        </LinkButton>
        <LinkButton
          href="/posts/"
          class="rounded-full border border-border px-6 py-3 text-sm font-medium transition hover:border-accent hover:text-accent"
        >
          📚 Browse all Q&A
        </LinkButton>
        <LinkButton
          href="/"
          class="rounded-full border border-border px-6 py-3 text-sm font-medium transition hover:border-accent hover:text-accent"
        >
          🏠 Home
        </LinkButton>
      </div>

      <div class="mt-12 w-full">
        <p class="mb-4 text-sm text-foreground/60">Or browse by country:</p>
        <ul class="flex flex-wrap justify-center gap-3">
          {
            countries.map(c => (
              <li>
                <a
                  href={`/tags/${slugifyTag(c.name)}/`}
                  class="flex items-center gap-2 rounded-full border border-border px-4 py-2 text-sm transition hover:border-accent hover:text-accent"
                >
                  <span class="text-lg">{c.emoji}</span>
                  <span>{c.name}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <p class="mt-12 text-xs text-foreground/50">
        If you arrived via an external link, please let us know which link is broken so we can fix it.
      </p>
    </div>
  </main>

  <Footer />
</Layout>
