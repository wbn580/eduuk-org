---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};

// EduUK · Bodleian Copper nav
const navItems = [
  { href: "/posts/", label: "Q&A" },
  { href: "/tags/", label: "Tags" },
  { href: "/tags/universities/", label: "Universities" },
  { href: "/tags/visa/", label: "Visa" },
  { href: "/tags/life/", label: "Life" },
  { href: "/archives/", label: "Archive" },
];
---

<a
  id="skip-to-content"
  href="#main-content"
  class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:start-3 focus:z-50 focus:rounded-md focus:bg-ink focus:px-3 focus:py-2 focus:text-cream"
>
  Skip to content
</a>

<header class="tg-nav-wrap">
  <div class="tg-nav">
    <a href="/" class="brand" aria-label={SITE.title}>
      <span class="brand-badge" aria-hidden="true">UK</span>
      <span class="brand-name">
        <b>edu<i>UK</i>.</b>
        <span class="brand-sub">UK Study · Answered Clearly</span>
      </span>
    </a>

    <nav id="nav-menu" aria-label="Primary">
      <button
        id="menu-btn"
        class="menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>

      <ul id="menu-items" class="nav-links hidden sm:flex">
        {
          navItems.map(item => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "nav-link",
                  { "is-active": isActive(item.href.replace(/\/$/, "")) },
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="nav-aux">
          <LinkButton
            href="/search/"
            class="nav-icon"
            title="Search"
            aria-label="Search"
          >
            <IconSearch />
          </LinkButton>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="nav-aux">
              <button
                id="theme-btn"
                class="nav-icon theme-btn"
                title="Toggle theme"
                aria-label="Toggle theme"
                aria-live="polite"
              >
                <IconMoon id="moon-ico" class="ico-moon" />
                <IconSunHigh id="sun-ico" class="ico-sun" />
              </button>
            </li>
          )
        }
        <li class="nav-cta-li">
          <a
            href="https://www.mikecrm.com/XnSiQG4"
            target="_blank"
            rel="nofollow noopener noreferrer"
            class="nav-cta"
          >Uni Match →</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .tg-nav-wrap {
    width: 100%;
    background: transparent;
  }
  .tg-nav {
    max-width: 1280px;
    margin: 0 auto;
    padding: 18px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }
  @media (max-width: 720px) {
    .tg-nav {
      padding: 14px 18px;
      flex-wrap: wrap;
    }
  }

  /* BRAND */
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    color: inherit;
    text-decoration: none;
  }
  .brand-badge {
    width: 44px;
    height: 44px;
    background: var(--maple);
    color: var(--cream);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 14px;
    letter-spacing: 0.05em;
    border: 2px solid var(--ink);
    box-shadow: 3px 3px 0 var(--ink);
    position: relative;
    flex-shrink: 0;
  }
  .brand-badge::after {
    content: "";
    position: absolute;
    inset: 3px;
    border: 1px dashed rgba(255, 255, 255, 0.32);
    border-radius: 7px;
  }
  .brand-name {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand-name b {
    font-size: 22px;
    font-weight: 900;
    letter-spacing: -0.03em;
  }
  .brand-name b i {
    font-style: normal;
    color: var(--maple);
  }
  .brand-sub {
    font-size: 10px;
    color: var(--pine);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-top: 4px;
  }
  :global([data-theme="dark"]) .brand-sub {
    color: var(--sun);
  }

  /* NAV LIST */
  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .nav-links.hidden {
    display: none;
  }
  @media (min-width: 640px) {
    .nav-links.hidden {
      display: flex;
    }
  }
  @media (max-width: 639px) {
    #nav-menu {
      width: 100%;
    }
    .nav-links {
      flex-direction: column;
      align-items: stretch;
      gap: 2px;
      width: 100%;
      margin-top: 10px;
      padding: 8px;
      border: 1.5px solid var(--ink);
      border-radius: 14px;
      background: var(--card);
      box-shadow: 3px 3px 0 var(--ink);
    }
    .nav-links li {
      width: 100%;
    }
    .nav-link,
    .nav-icon,
    .nav-cta {
      width: 100%;
      justify-content: flex-start;
    }
  }

  .nav-link {
    font-size: 14px;
    font-weight: 600;
    padding: 8px 14px;
    border-radius: 999px;
    color: var(--ink-2);
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }
  .nav-link:hover {
    background: var(--cream);
    color: var(--ink);
  }
  .nav-link.is-active {
    background: var(--ink);
    color: var(--cream);
  }
  :global([data-theme="dark"]) .nav-link:hover {
    background: var(--card);
    color: var(--sun);
  }
  :global([data-theme="dark"]) .nav-link.is-active {
    background: var(--sun);
    color: var(--ink);
  }

  .nav-aux {
    display: inline-flex;
  }
  .nav-icon {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: var(--ink-2);
    background: transparent;
    border: none;
    transition: color 0.15s, background 0.15s;
  }
  .nav-icon:hover {
    background: var(--cream);
    color: var(--maple);
  }
  .nav-icon :global(svg) {
    width: 18px;
    height: 18px;
  }

  .theme-btn {
    position: relative;
  }
  .theme-btn :global(.ico-moon),
  .theme-btn :global(.ico-sun) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.2s, opacity 0.2s;
  }
  :global([data-theme="light"]) .theme-btn :global(.ico-sun),
  :global(:root:not([data-theme="dark"])) .theme-btn :global(.ico-sun) {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scale(0);
  }
  :global([data-theme="dark"]) .theme-btn :global(.ico-moon) {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(-90deg) scale(0);
  }

  .nav-cta-li {
    margin-left: 6px;
  }
  .nav-cta {
    background: var(--maple);
    color: var(--cream);
    border: 2px solid var(--ink);
    box-shadow: 3px 3px 0 var(--ink);
    font-family: inherit;
    font-weight: 800;
    font-size: 13px;
    padding: 10px 18px;
    border-radius: 999px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    transition: transform 0.15s, box-shadow 0.15s;
    text-decoration: none;
  }
  .nav-cta:hover {
    transform: translate(-1px, -1px);
    box-shadow: 4px 4px 0 var(--ink);
  }
  .nav-cta:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 var(--ink);
  }

  /* Mobile hamburger */
  .menu-btn {
    display: none;
    background: transparent;
    border: 1.5px solid var(--ink);
    color: var(--ink);
    border-radius: 10px;
    padding: 6px;
    margin-left: auto;
  }
  .menu-btn :global(svg) {
    width: 22px;
    height: 22px;
  }
  @media (max-width: 639px) {
    .menu-btn {
      display: inline-flex;
    }
  }
  .menu-btn :global(.hidden) {
    display: none;
  }
</style>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";
      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open menu" : "Close menu");
      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>
