---
import type { HTMLAttributes } from "astro/types";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const colContent = [
  { label: "All Q&A", href: "/posts/" },
  { label: "Tags", href: "/tags/" },
  { label: "Archive", href: "/archives/" },
  { label: "RSS feed", href: "/rss.xml" },
];

const colServices: { label: string; href: string; external?: boolean }[] = [
  {
    label: "Uni Match assessment",
    href: "https://www.mikecrm.com/XnSiQG4",
    external: true,
  },
  { label: "Visa pathway", href: "/tags/visa/" },
  { label: "Accommodation help", href: "/tags/accommodation/" },
  { label: "Student life", href: "/tags/life/" },
];

const colAbout = [
  { label: "About eduUK", href: "/about/" },
  { label: "Resources", href: "/resources/" },
  { label: "Privacy", href: "/privacy/" },
  { label: "Disclaimer", href: "/disclaimer/" },
];
---

<footer
  class:list={["tg-foot", { "tg-foot--push": !noMarginTop }, className]}
  {...attrs}
>
  <div class="foot-inner">
    <div class="foot-brand">
      <a href="/" class="brand" aria-label="eduUK · Home">
        <span class="brand-badge" aria-hidden="true">UK</span>
        <span class="brand-name">
          <b>edu<i>UK</i>.</b>
          <span class="brand-sub">UK Study · Answered Clearly</span>
        </span>
      </a>
      <p>
        A factual English-language knowledge base for international students heading to the United Kingdom. Data grounded in UKVI, UCAS, HESA and UKCISA — updated regularly, no sponsored rankings.
      </p>
    </div>

    <div>
      <h5>Content</h5>
      <ul>
        {colContent.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>

    <div>
      <h5>Services</h5>
      <ul>
        {
          colServices.map(l => (
            <li>
              <a
                href={l.href}
                {...(l.external
                  ? { target: "_blank", rel: "nofollow noopener noreferrer" }
                  : {})}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h5>About</h5>
      <ul>
        {colAbout.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>
  </div>

  <div class="colophon">
    <span>set in Plus Jakarta Sans · Caveat · JetBrains Mono</span>
    <span>published on cloudflare pages · built with astro</span>
    <span>eduuk.org · ©{currentYear}</span>
  </div>
</footer>

<style>
  .tg-foot {
    background: var(--ink);
    color: #d4c9a8;
    padding: 54px 0 28px;
  }
  .tg-foot--push {
    margin-top: 80px;
  }
  .foot-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 28px;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 36px;
  }
  @media (max-width: 900px) {
    .foot-inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 520px) {
    .foot-inner {
      grid-template-columns: 1fr;
    }
  }

  .foot-brand .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    color: inherit;
    text-decoration: none;
    margin-bottom: 14px;
  }
  .brand-badge {
    width: 44px;
    height: 44px;
    background: var(--sun);
    color: var(--ink);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 14px;
    letter-spacing: 0.05em;
    border: 2px solid var(--sun);
    box-shadow: 3px 3px 0 rgba(255, 255, 255, 0.08);
    position: relative;
    flex-shrink: 0;
  }
  .brand-badge::after {
    content: "";
    position: absolute;
    inset: 3px;
    border: 1px dashed rgba(0, 0, 0, 0.25);
    border-radius: 7px;
  }
  .brand-name {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand-name b {
    font-size: 22px;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--cream);
  }
  .brand-name b i {
    font-style: normal;
    color: var(--sun);
  }
  .brand-sub {
    font-size: 10px;
    color: var(--sun);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .foot-brand p {
    font-size: 13.5px;
    color: #b0a485;
    margin: 0;
    line-height: 1.6;
  }

  .tg-foot h5 {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sun);
    font-weight: 800;
    margin: 0 0 14px;
  }
  .tg-foot ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tg-foot li {
    font-size: 13.5px;
    padding: 5px 0;
  }
  .tg-foot li a {
    color: #b0a485;
    text-decoration: none;
    transition: color 0.15s;
  }
  .tg-foot li a:hover {
    color: #fff;
  }

  .colophon {
    max-width: 1280px;
    margin: 32px auto 0;
    padding: 20px 28px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(176, 164, 133, 0.6);
    letter-spacing: 0.05em;
  }
</style>
