---
import { ClientRouter } from "astro:transitions";
import {
  PUBLIC_GOOGLE_SITE_VERIFICATION,
  PUBLIC_BING_VERIFICATION,
  PUBLIC_YANDEX_VERIFICATION,
} from "astro:env/client";
import { SITE } from "@/config";
import FloatingActions from "@/components/FloatingActions.astro";
import "@/styles/global.css";

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  tags?: string[];
};

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  tags,
} = Astro.props;

// Meta keywords: used by article pages (tags) or site-wide keywords for other pages
const metaKeywords =
  tags && tags.length > 0
    ? tags.join(", ")
    : "UK study, UK universities, UK student visa, UK Master's degree, UK accommodation, UK student life, UCAS, Russell Group, G5 universities, international students";

const socialImageURL = new URL(ogImage, Astro.url);

// Posts (with pubDatetime) output both BlogPosting and QAPage structured data:
// - BlogPosting: helps Google / social sharing recognize it as an article
// - QAPage: tells AI crawlers (ChatGPT / Perplexity / Gemini) this is Q&A format
const isPost = Boolean(pubDatetime);

const blogPostingSchema = isPost
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: `${title}`,
      image: `${socialImageURL}`,
      datePublished: pubDatetime!.toISOString(),
      ...(modDatetime && { dateModified: modDatetime.toISOString() }),
      author: [
        {
          "@type": "Person",
          name: `${author}`,
          ...(profile && { url: profile }),
        },
      ],
    }
  : null;

const qaPageSchema = isPost
  ? {
      "@context": "https://schema.org",
      "@type": "QAPage",
      mainEntity: {
        "@type": "Question",
        name: `${title}`,
        text: `${title}`,
        answerCount: 1,
        acceptedAnswer: {
          "@type": "Answer",
          text: `${description}`,
          url: `${canonicalURL}`,
          dateCreated: `${pubDatetime?.toISOString()}`,
          author: {
            "@type": "Organization",
            name: `${SITE.author}`,
            url: SITE.website,
          },
        },
      },
    }
  : null;

// Non-article pages output WebSite + Organization structured data
// Helps Google build Knowledge Panel and SiteLinks Search Box
const websiteSchema = !isPost
  ? {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE.title,
      alternateName: "eduuk.org",
      url: SITE.website,
      inLanguage: SITE.lang,
      description: SITE.desc,
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: `${SITE.website.replace(/\/$/, "")}/search?q={search_term_string}`,
        },
        "query-input": "required name=search_term_string",
      },
      publisher: {
        "@type": "Organization",
        name: SITE.author,
        url: SITE.website,
      },
    }
  : null;

const organizationSchema = !isPost
  ? {
      "@context": "https://schema.org",
      "@type": "Organization",
      name: SITE.author,
      alternateName: "Study in UK",
      url: SITE.website,
      logo: new URL("/favicon.svg", SITE.website).toString(),
      description: SITE.desc,
      sameAs: [] as string[],
      knowsAbout: [
        "UK higher education",
        "UK university applications",
        "G5 universities",
        "Russell Group",
        "UCAS applications",
        "UK Student Visa",
        "Graduate Route",
        "IELTS preparation",
        "UK student scholarships",
        "UK student accommodation",
        "UK international student life",
      ],
    }
  : null;
---

<!doctype html>
<html
  dir={SITE.dir}
  lang=`${SITE.lang ?? "en"}`
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="baidu-site-verification" content="codeva-9lYXfabrYj" />

    <!-- Favicon: SVG favicon is supported by all modern browsers (2020+) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={metaKeywords} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter / X -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- JSON-LD Structured data (for search engines) -->
    {
      blogPostingSchema && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(blogPostingSchema)}
        />
      )
    }
    {
      qaPageSchema && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(qaPageSchema)}
        />
      )
    }
    {
      websiteSchema && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(websiteSchema)}
        />
      )
    }
    {
      organizationSchema && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(organizationSchema)}
        />
      )
    }

    <!-- Enable RSS feed auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    <meta name="theme-color" content="" />

    <!-- Search engine verification meta tags (only output if configured) -->
    {
      PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }
    {
      PUBLIC_BING_VERIFICATION && (
        <meta name="msvalidate.01" content={PUBLIC_BING_VERIFICATION} />
      )
    }
    {
      PUBLIC_YANDEX_VERIFICATION && (
        <meta
          name="yandex-verification"
          content={PUBLIC_YANDEX_VERIFICATION}
        />
      )
    }

    <ClientRouter />

    <!-- Minimal inline script to prevent FOUC - sets theme immediately -->
    <script is:inline>
      (function () {
        const initialColorScheme = "";
        const currentTheme = localStorage.getItem("theme");

        function getPreferTheme() {
          if (currentTheme) return currentTheme;
          if (initialColorScheme) return initialColorScheme;
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        const themeValue = getPreferTheme();

        // Set theme immediately to prevent flash
        document.firstElementChild?.setAttribute("data-theme", themeValue);

        // Export minimal API for external script
        window.theme = {
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          setTheme: val => {
            window.theme.themeValue = val;
          },
        };
      })();
    </script>
  </head>
  <body>
    <slot />

    <!-- Shared floating action button: Uni Match assessment -->
    <FloatingActions />

    <!-- Load full theme logic -->
    <script src="../scripts/theme.ts"></script>
  </body>
</html>
